# Set these in Railway → Backend service → Variables

# Activation
SPRING_PROFILES_ACTIVE=prod

# Database (copy from Railway PostgreSQL service)
SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/railway
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-password

# CORS — your Vercel frontend URL
ALLOWED_ORIGINS=https://your-app.vercel.app

# ML service URL (Railway ML service)
ML_API_URL=https://your-ml.railway.app

# External APIs
GEMINI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
AZURE_STORAGE_CONNECTION_STRING=
